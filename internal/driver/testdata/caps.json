{
  "engine": "ydb",
  "contract": "1.0",
  "transports": [
    "local",
    "docker"
  ],
  "axes": {
    "lifecycle": [
      "up",
      "down",
      "restart",
      "status",
      "wait",
      "provision",
      "destroy"
    ],
    "meta": [
      "caps",
      "info",
      "version",
      "schema",
      "doctor"
    ]
  },
  "features": {
    "remote": false,
    "prune": true,
    "ephemeralPrefix": true,
    "snapshot": false
  }
}
